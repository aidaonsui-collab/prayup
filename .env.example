# ── MiniMax (server-side prayer generation) ──────────────────────────────
# Used by api/prayer.ts (Vercel) and the local Vite dev middleware.
MINIMAX_API_KEY=
# Optional. Defaults: https://api.minimaxi.chat/v1 and MiniMax-M2.7
# MINIMAX_BASE_URL=
# MINIMAX_MODEL=

# ── Supabase (auth + cross-device sync + push subscriptions) ─────────────
# Client (VITE_ prefix is required so Vite exposes them to the browser):
VITE_SUPABASE_URL=https://boatyhrefcilcxepnbbf.supabase.co
VITE_SUPABASE_ANON_KEY=
# Server (used by /api/subscribe, /api/unsubscribe, /api/send-reminders):
SUPABASE_URL=https://boatyhrefcilcxepnbbf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# (anon key is also read here as a fallback for verifying user tokens)
SUPABASE_ANON_KEY=

# ── Web Push (daily reminders) ────────────────────────────────────────────
# Public key — exposed to the browser via VITE_ prefix:
VITE_VAPID_PUBLIC_KEY=
# Server-side keys for signing pushes:
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@prayup.app

# ── Cron auth ─────────────────────────────────────────────────────────────
# A long random string. Vercel Cron sets x-vercel-cron automatically; this
# secret protects manual invocations.
CRON_SECRET=
